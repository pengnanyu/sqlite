{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "assets": {
    "directory": "dist",
    "include": ["*.html", "*.css", "*.js", "*.wasm"]
  },
  "functionJsFilePath": "_worker.js",
  "routes": {
    "include": ["/*"]
  },
  "kv": [
    {
      "binding": "DB_KV",
      "namespace": "sqlite-online-db"
    }
  ]
}
