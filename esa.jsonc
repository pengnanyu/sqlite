{
  "assets": {
    "directory": "./admin"
  },
  "install": {
    "command": "npm install"
  },
  "build": {
    "command": "npx esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=browser --target=es2022 --external:node:*",
    "outputDirectory": "dist"
  },
  "function": {
    "filePath": "dist/index.js"
  }
}